<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Clear any globally registered iisnode handler to avoid naming conflicts -->
      <remove name="iisnode" />
      <!-- Indicates that the server.js file is a node.js site to be handled by the iisnode module -->
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <!-- Route all requests to the startup file -->
        <rule name="TolidayPortalDynamicContent">
          <match url=".*" />
          <conditions>
            <!-- Do not rewrite requests for existing files (like static assets) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
